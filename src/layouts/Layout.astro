---
interface Props {
title: string;
description: string;
image?: string;
canonical?: string;
structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
title,
description,
image = '/images/source/_DSC6127.JPG',
canonical,
structuredData,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const canonicalUrl = canonical
? new URL(canonical, site).toString()
: new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();
const structuredDataList = Array.isArray(structuredData)
? structuredData
: structuredData
? [structuredData]
: [];
---

<!doctype html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="theme-color" content="#dd0033" />
<link rel="canonical" href={canonicalUrl} />
<link rel="icon" type="image/png" href="/images/source/fundacionlogo400.png" />
<link rel="apple-touch-icon" href="/images/source/fundacionlogo400.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
<link href="https://fonts.googleapis.com/css2?family=Signika:wght@400;600;700&family=Enriqueta:wght@400;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<meta property="og:locale" content="es_ES" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Fundacion Fair Play" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
<title>{title}</title>
{structuredDataList.map((entry) => (
<script type="application/ld+json" set:html={JSON.stringify(entry)} />
))}
</head>
<body>
<slot />
</body>
</html>

<style is:global>
:root {
color-scheme: light;
--bg: #ffffff;
--bg-strong: #dd0033;
--surface: #ffffff;
--surface-strong: #f4f4f4;
--text: #666464;
--muted: #666464;
--line: rgba(0, 0, 0, 0.08);
--accent: #dd0033;
--shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

* {
box-sizing: border-box;
}

html {
scroll-behavior: smooth;
font-family: 'Signika', sans-serif;
font-size: 16px;
line-height: 1.6;
-webkit-font-smoothing: antialiased;
-moz-osx-font-smoothing: grayscale;
}

h1, h2, h3, h4, h5, h6 {
font-family: 'Enriqueta', serif;
color: var(--accent);
}

body {
margin: 0;
min-width: 320px;
color: var(--text);
background: #ffffff;
}

a {
color: inherit;
}

img {
display: block;
max-width: 100%;
}

button,
input,
textarea,
select {
font: inherit;
}

.container {
width: 90%;
max-width: 1250px;
margin: 0 auto;
}

.section-label {
display: inline-flex;
align-items: center;
gap: 0.65rem;
padding: 0.45rem 0.85rem;
border-radius: 999px;
background: #ffffff;
border: 1px solid rgba(0, 0, 0, 0.08);
font-size: 0.8rem;
font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--accent);
}

.section-title {
margin: 1rem 0 0.9rem;
font-family: 'Enriqueta', serif;
font-size: 2rem;
line-height: 1.2;
color: var(--accent);
}

.section-copy {
max-width: 62ch;
margin: 0;
font-size: 1rem;
line-height: 1.8;
color: var(--muted);
}

.sr-only {
position: absolute;
width: 1px;
height: 1px;
padding: 0;
margin: -1px;
overflow: hidden;
clip: rect(0, 0, 0, 0);
white-space: nowrap;
border: 0;
}

@media (max-width: 768px) {
.container {
width: 90%;
}
}
</style>
